# NextAuth
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
NEXTAUTH_URL=http://localhost:3000

# Convex (auto-populated by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_SITE_URL=https://your-deployment.convex.site

# RSA key pair for Convex JWT auth
# Generate with: node scripts/generate-auth-keys.js
CONVEX_AUTH_PRIVATE_KEY=base64-encoded-pkcs8-private-key
CONVEX_AUTH_PUBLIC_KEY=base64-encoded-spki-public-key
# Also set CONVEX_AUTH_PUBLIC_KEY in Convex dashboard:
# npx convex env set CONVEX_AUTH_PUBLIC_KEY "your-base64-public-key"
